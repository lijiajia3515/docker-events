# 必需（至少配置一个通知渠道）
# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_IDS=C01234567,C0ABCDEF0

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AbCdEfGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_IDS=123456789,-987654321

# Discord Bot（传统方式）
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432

# Discord Webhook（推荐用于简单通知，仅使用 HTTP）
# 可以单独使用 webhook，也可以与 bot 组合使用以发送到不同频道
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/123456789/your-webhook-token

# Microsoft Teams Webhook
TEAMS_WEBHOOK_URLS=https://your-tenant.webhook.office.com/webhookb2/your-webhook-token

# 企业微信 Webhook
WECOM_WEBHOOK_URLS=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 钉钉 Webhook
DINGTALK_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=your-token

# 可选配置
NOTIFY_SUBJECT=Docker 事件
DOCKER_EVENT_FILTERS=
DOCKER_EVENT_TYPES=container,image,volume

# 消息自定义
# 使用 Go 模板语法的自定义消息模板
# 可用占位符:
#   {{.Type}} - 事件类型 (container, image, volume 等)
#   {{.Action}} - 事件动作 (start, stop, create 等)
#   {{.ID}} - 完整对象 ID
#   {{.ShortID}} - 短 ID (前12个字符)
#   {{.Name}} - 容器/对象名称 (如果可用)
#   {{.Status}} - 事件状态
#   {{.From}} - 来源字段 (容器的镜像名称)
#   {{.Time}} - 事件时间戳 (RFC3339 格式)
#   {{.Scope}} - 事件范围 (local 或 swarm)
#   {{.Actor.ID}} - 执行者 ID
#   {{.Attribute "key"}} - 按键获取特定属性
#   {{.GetLogs}} - 容器日志 (仅当 MESSAGE_LOG_LINES > 0 时可用)
#
# 示例模板:
# 简单: 容器 {{.Name}} ({{.ShortID}}) {{.Action}} 时间: {{.Time}}
# 带日志: 容器 {{.Name}} 已启动\n日志:\n{{.GetLogs}}
# MESSAGE_TEMPLATE=容器 {{.Name}} ({{.ShortID}}) {{.Action}} 时间: {{.Time}}

# 容器事件日志获取行数 (0 = 禁用)
# MESSAGE_LOG_LINES=10
